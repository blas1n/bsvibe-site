---
export const prerender = false;
import DashboardLayout from '@/layouts/DashboardLayout.astro';

const user = Astro.locals.user!;
---

<DashboardLayout title="Team — BSVibe" locale="en">
  <h1 class="page-title">Team</h1>
  <p class="page-desc">Invite team members and manage permissions.</p>

  <div class="team-current">
    <h2>Current Members</h2>
    <table class="member-table">
      <thead><tr><th>Email</th><th>Role</th></tr></thead>
      <tbody>
        <tr>
          <td>{user.email} <span class="you-badge">YOU</span></td>
          <td>{user.role}</td>
        </tr>
      </tbody>
    </table>
  </div>

  <div class="invite-section">
    <h2>Invite Members</h2>
    <p>Team collaboration is available on Pro plans.</p>
    <div class="coming-soon">
      <p>Member invitations coming soon</p>
      <p class="hint">Currently in single-user mode. For team features, contact <a href="mailto:contact@bsvibe.dev">contact@bsvibe.dev</a>.</p>
    </div>
  </div>
</DashboardLayout>

<style>
  .page-title { color: #f2f3f7; font-size: 1.5rem; font-weight: 700; margin-bottom: 8px; letter-spacing: -0.02em; }
  .page-desc { color: #8187a8; font-size: 0.9375rem; margin-bottom: 32px; }
  .team-current { margin-bottom: 40px; }
  .team-current h2, .invite-section h2 { color: #f2f3f7; font-size: 1rem; font-weight: 600; margin-bottom: 16px; }
  .invite-section p { color: #8187a8; font-size: 0.875rem; margin-bottom: 16px; }
  .member-table { width: 100%; border-collapse: collapse; border: 1px solid #2a2d42; border-radius: 12px; overflow: hidden; }
  .member-table th, .member-table td { padding: 12px 16px; text-align: left; border-bottom: 1px solid #1e2033; font-size: 0.875rem; }
  .member-table th { background-color: #111218; color: #5a5f7d; font-weight: 600; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.04em; }
  .member-table td { color: #a8adc6; }
  .member-table tbody tr:last-child td { border-bottom: none; }
  .you-badge { display: inline-block; margin-left: 8px; padding: 1px 6px; border-radius: 4px; background-color: rgba(99,102,241,0.12); color: #818cf8; font-size: 0.625rem; font-weight: 700; letter-spacing: 0.04em; }
  .coming-soon { padding: 32px; border-radius: 12px; border: 1px dashed #2a2d42; text-align: center; }
  .coming-soon p { color: #5a5f7d; font-size: 0.875rem; margin: 0; }
  .coming-soon .hint { margin-top: 8px; font-size: 0.8125rem; }
  .coming-soon a { color: #818cf8; text-decoration: none; }
  .coming-soon a:hover { text-decoration: underline; }
</style>
