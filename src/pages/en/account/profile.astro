---
export const prerender = false;
import DashboardLayout from '@/layouts/DashboardLayout.astro';

const user = Astro.locals.user!;
---

<DashboardLayout title="Profile — BSVibe" locale="en">
  <h1 class="page-title">Profile</h1>
  <p class="page-desc">View your account information.</p>

  <div class="profile-card">
    <dl>
      <div>
        <dt>Email</dt>
        <dd>{user.email}</dd>
      </div>
      <div>
        <dt>User ID</dt>
        <dd><code>{user.id}</code></dd>
      </div>
      <div>
        <dt>Tenant ID</dt>
        <dd><code>{user.tenantId || '—'}</code></dd>
      </div>
      <div>
        <dt>Role</dt>
        <dd>{user.role}</dd>
      </div>
    </dl>

    <div class="actions">
      <a href="https://auth.bsvibe.dev/account" class="action-link">Change password →</a>
    </div>
  </div>

  <div class="danger-zone">
    <h2>Delete Account</h2>
    <p>Deleting your account permanently removes all data within 30 days.</p>
    <a href="mailto:contact@bsvibe.dev?subject=Account Deletion Request" class="danger-link">Request deletion</a>
  </div>
</DashboardLayout>

<style>
  .page-title { color: #f2f3f7; font-size: 1.5rem; font-weight: 700; margin-bottom: 8px; letter-spacing: -0.02em; }
  .page-desc { color: #8187a8; font-size: 0.9375rem; margin-bottom: 32px; }
  .profile-card { padding: 24px; border-radius: 12px; border: 1px solid #2a2d42; background-color: #111218; margin-bottom: 32px; }
  dl { display: flex; flex-direction: column; gap: 16px; margin: 0; }
  dl > div { display: grid; grid-template-columns: 140px 1fr; gap: 16px; align-items: baseline; }
  dt { font-size: 0.8125rem; color: #5a5f7d; font-weight: 500; }
  dd { color: #e4e6ee; font-size: 0.9375rem; margin: 0; }
  dd code { font-family: 'JetBrains Mono', monospace; background-color: rgba(99,102,241,0.08); padding: 2px 8px; border-radius: 4px; font-size: 0.8125rem; color: #818cf8; }
  .actions { margin-top: 24px; padding-top: 20px; border-top: 1px solid #1e2033; }
  .action-link { color: #818cf8; font-size: 0.875rem; text-decoration: none; }
  .action-link:hover { color: #a5b4fc; }
  .danger-zone { padding: 24px; border-radius: 12px; border: 1px solid rgba(244,63,94,0.2); background-color: rgba(244,63,94,0.04); }
  .danger-zone h2 { color: #fb7185; font-size: 1rem; font-weight: 600; margin-bottom: 8px; }
  .danger-zone p { color: #8187a8; font-size: 0.875rem; margin-bottom: 16px; }
  .danger-link { display: inline-block; padding: 8px 16px; border-radius: 6px; border: 1px solid rgba(244,63,94,0.3); color: #fb7185; font-size: 0.8125rem; text-decoration: none; transition: all 0.15s ease; }
  .danger-link:hover { background-color: rgba(244,63,94,0.1); }
</style>
