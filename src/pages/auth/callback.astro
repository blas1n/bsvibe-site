---
export const prerender = false;
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="로그인 중..." description="BSVibe 인증 처리 중" locale="ko">
  <div class="callback-container">
    <div class="spinner" />
    <p>로그인 처리 중...</p>
  </div>
</BaseLayout>

<script>
  async function handleCallback() {
    const hash = window.location.hash.substring(1);
    if (!hash) {
      window.location.href = '/';
      return;
    }

    const params = new URLSearchParams(hash);
    const accessToken = params.get('access_token');
    const refreshToken = params.get('refresh_token');
    const state = params.get('state');

    if (!accessToken || !refreshToken) {
      window.location.href = '/';
      return;
    }

    // Send refresh token to server to set httpOnly cookie
    try {
      await fetch('/api/auth/session', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ refresh_token: refreshToken }),
      });
    } catch {
      // Continue even if cookie setting fails
    }

    // Clear hash fragment
    history.replaceState(null, '', window.location.pathname);

    // Redirect to account or original destination
    const returnUrl = state ? decodeURIComponent(state) : '/account';
    window.location.href = returnUrl;
  }

  handleCallback();
</script>

<style>
  .callback-container {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
  }
  .callback-container p {
    color: #8187a8;
    font-size: 0.9375rem;
  }
  .spinner {
    width: 32px;
    height: 32px;
    border: 3px solid #2a2d42;
    border-top-color: #6366f1;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }
  @keyframes spin {
    to { transform: rotate(360deg); }
  }
</style>
