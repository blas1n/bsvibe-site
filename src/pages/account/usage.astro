---
export const prerender = false;
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import { getUsage, isBSGatewayConfigured } from '@/lib/bsgateway.server';

const user = Astro.locals.user!;
const period = (Astro.url.searchParams.get('period') ?? 'month') as 'day' | 'week' | 'month';
const usage = user.tenantId ? await getUsage(user.tenantId, period) : null;
const configured = isBSGatewayConfigured();

const periodLabels: Record<string, string> = {
  day: '오늘',
  week: '이번 주',
  month: '이번 달',
};
---

<DashboardLayout title="사용량 — BSVibe" locale="ko">
  <h1 class="page-title">사용량</h1>
  <p class="page-desc">BSGateway API 호출 수와 토큰 사용량을 확인합니다.</p>

  <div class="period-tabs">
    {(['day', 'week', 'month'] as const).map(p => (
      <a href={`?period=${p}`} class:list={['tab', { active: period === p }]}>
        {periodLabels[p]}
      </a>
    ))}
  </div>

  {!configured ? (
    <div class="empty">
      <p>BSGateway가 아직 연결되지 않았습니다.</p>
      <p class="hint">관리자: <code>BSGATEWAY_API_KEY</code> 환경 변수를 설정하세요.</p>
    </div>
  ) : !user.tenantId ? (
    <div class="empty">
      <p>테넌트가 할당되지 않았습니다.</p>
      <p class="hint">관리자에게 문의하세요.</p>
    </div>
  ) : !usage ? (
    <div class="empty">
      <p>사용량 데이터를 불러올 수 없습니다.</p>
    </div>
  ) : (
    <>
      <div class="stat-grid">
        <div class="stat-card">
          <div class="stat-label">총 요청 수</div>
          <div class="stat-value">{usage.total_requests.toLocaleString('ko-KR')}</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">총 토큰 수</div>
          <div class="stat-value">{usage.total_tokens.toLocaleString('ko-KR')}</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">사용 모델 수</div>
          <div class="stat-value">{Object.keys(usage.by_model).length}</div>
        </div>
      </div>

      {Object.keys(usage.by_model).length > 0 && (
        <section class="section">
          <h2>모델별 사용량</h2>
          <table class="usage-table">
            <thead>
              <tr>
                <th>모델</th>
                <th>요청 수</th>
                <th>토큰 수</th>
              </tr>
            </thead>
            <tbody>
              {Object.entries(usage.by_model)
                .sort(([, a], [, b]) => b.requests - a.requests)
                .map(([model, stats]) => (
                  <tr>
                    <td><code>{model}</code></td>
                    <td>{stats.requests.toLocaleString('ko-KR')}</td>
                    <td>{stats.tokens.toLocaleString('ko-KR')}</td>
                  </tr>
                ))}
            </tbody>
          </table>
        </section>
      )}

      {usage.daily_breakdown.length > 0 && (
        <section class="section">
          <h2>일별 사용량</h2>
          <div class="daily-chart">
            {usage.daily_breakdown.slice(-14).map(d => {
              const max = Math.max(...usage.daily_breakdown.map(x => x.requests), 1);
              const height = (d.requests / max) * 100;
              return (
                <div class="bar-wrap" title={`${d.date}: ${d.requests} requests`}>
                  <div class="bar" style={`height: ${height}%;`} />
                  <div class="bar-label">{d.date.slice(5)}</div>
                </div>
              );
            })}
          </div>
        </section>
      )}
    </>
  )}
</DashboardLayout>

<style>
  .page-title {
    color: #f2f3f7;
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 8px;
    letter-spacing: -0.02em;
  }
  .page-desc {
    color: #8187a8;
    font-size: 0.9375rem;
    margin-bottom: 24px;
  }
  .period-tabs {
    display: flex;
    gap: 4px;
    margin-bottom: 24px;
    border-bottom: 1px solid #1e2033;
  }
  .tab {
    padding: 10px 16px;
    color: #8187a8;
    font-size: 0.875rem;
    text-decoration: none;
    border-bottom: 2px solid transparent;
    transition: all 0.15s ease;
  }
  .tab:hover {
    color: #f2f3f7;
  }
  .tab.active {
    color: #818cf8;
    border-bottom-color: #6366f1;
  }
  .empty {
    padding: 48px;
    border-radius: 12px;
    border: 1px dashed #2a2d42;
    text-align: center;
    color: #5a5f7d;
  }
  .empty .hint {
    margin-top: 8px;
    font-size: 0.8125rem;
    color: #3d4160;
  }
  .empty code {
    font-family: 'JetBrains Mono', monospace;
    background-color: rgba(99,102,241,0.08);
    padding: 1px 6px;
    border-radius: 4px;
    color: #818cf8;
  }
  .stat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 12px;
    margin-bottom: 32px;
  }
  .stat-card {
    padding: 24px;
    border-radius: 12px;
    border: 1px solid #2a2d42;
    background-color: #111218;
  }
  .stat-label {
    font-size: 0.75rem;
    color: #5a5f7d;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 8px;
  }
  .stat-value {
    font-size: 1.75rem;
    font-weight: 800;
    color: #f2f3f7;
    letter-spacing: -0.02em;
  }
  .section {
    margin-bottom: 32px;
  }
  .section h2 {
    color: #f2f3f7;
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 16px;
  }
  .usage-table {
    width: 100%;
    border-collapse: collapse;
    border: 1px solid #2a2d42;
    border-radius: 12px;
    overflow: hidden;
  }
  .usage-table th, .usage-table td {
    padding: 12px 16px;
    text-align: left;
    border-bottom: 1px solid #1e2033;
    font-size: 0.875rem;
  }
  .usage-table th {
    background-color: #111218;
    color: #5a5f7d;
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .usage-table td {
    color: #a8adc6;
  }
  .usage-table code {
    font-family: 'JetBrains Mono', monospace;
    color: #818cf8;
    font-size: 0.8125rem;
  }
  .usage-table tbody tr:last-child td {
    border-bottom: none;
  }
  .daily-chart {
    display: flex;
    align-items: flex-end;
    gap: 8px;
    height: 200px;
    padding: 16px;
    border-radius: 12px;
    border: 1px solid #2a2d42;
    background-color: #111218;
  }
  .bar-wrap {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    height: 100%;
    justify-content: flex-end;
    gap: 6px;
  }
  .bar {
    width: 100%;
    background: linear-gradient(180deg, #818cf8, #6366f1);
    border-radius: 4px 4px 0 0;
    min-height: 2px;
    transition: opacity 0.15s ease;
  }
  .bar:hover {
    opacity: 0.8;
  }
  .bar-label {
    font-size: 0.6875rem;
    color: #5a5f7d;
  }
</style>
