---
export const prerender = false;
import DashboardLayout from '@/layouts/DashboardLayout.astro';

const user = Astro.locals.user!;
---

<DashboardLayout title="프로필 — BSVibe" locale="ko">
  <h1 class="page-title">프로필</h1>
  <p class="page-desc">계정 정보를 확인합니다.</p>

  <div class="profile-card">
    <dl>
      <div>
        <dt>이메일</dt>
        <dd>{user.email}</dd>
      </div>
      <div>
        <dt>사용자 ID</dt>
        <dd><code>{user.id}</code></dd>
      </div>
      <div>
        <dt>테넌트 ID</dt>
        <dd><code>{user.tenantId || '—'}</code></dd>
      </div>
      <div>
        <dt>역할</dt>
        <dd>{user.role}</dd>
      </div>
    </dl>

    <div class="actions">
      <a href="https://auth.bsvibe.dev/account" class="action-link">비밀번호 변경 →</a>
    </div>
  </div>

  <div class="danger-zone">
    <h2>계정 삭제</h2>
    <p>계정을 삭제하면 모든 데이터가 30일 이내에 영구 삭제됩니다.</p>
    <a href="mailto:contact@bsvibe.dev?subject=계정 삭제 요청" class="danger-link">삭제 요청 보내기</a>
  </div>
</DashboardLayout>

<style>
  .page-title {
    color: #f2f3f7;
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 8px;
    letter-spacing: -0.02em;
  }
  .page-desc {
    color: #8187a8;
    font-size: 0.9375rem;
    margin-bottom: 32px;
  }
  .profile-card {
    padding: 24px;
    border-radius: 12px;
    border: 1px solid #2a2d42;
    background-color: #111218;
    margin-bottom: 32px;
  }
  dl {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin: 0;
  }
  dl > div {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 16px;
    align-items: baseline;
  }
  dt {
    font-size: 0.8125rem;
    color: #5a5f7d;
    font-weight: 500;
  }
  dd {
    color: #e4e6ee;
    font-size: 0.9375rem;
    margin: 0;
  }
  dd code {
    font-family: 'JetBrains Mono', monospace;
    background-color: rgba(99,102,241,0.08);
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 0.8125rem;
    color: #818cf8;
  }
  .actions {
    margin-top: 24px;
    padding-top: 20px;
    border-top: 1px solid #1e2033;
  }
  .action-link {
    color: #818cf8;
    font-size: 0.875rem;
    text-decoration: none;
  }
  .action-link:hover {
    color: #a5b4fc;
  }
  .danger-zone {
    padding: 24px;
    border-radius: 12px;
    border: 1px solid rgba(244,63,94,0.2);
    background-color: rgba(244,63,94,0.04);
  }
  .danger-zone h2 {
    color: #fb7185;
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 8px;
  }
  .danger-zone p {
    color: #8187a8;
    font-size: 0.875rem;
    margin-bottom: 16px;
  }
  .danger-link {
    display: inline-block;
    padding: 8px 16px;
    border-radius: 6px;
    border: 1px solid rgba(244,63,94,0.3);
    color: #fb7185;
    font-size: 0.8125rem;
    text-decoration: none;
    transition: all 0.15s ease;
  }
  .danger-link:hover {
    background-color: rgba(244,63,94,0.1);
  }
</style>
