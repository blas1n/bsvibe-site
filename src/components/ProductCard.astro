---
import type { ProductMeta } from '@/data/products';

interface Props {
  product: ProductMeta;
  detail: string;
  desc: string;
  index: number;
}

const { product, detail, desc, index } = Astro.props;
const p = product;
---

<a href={p.href} class="product-card fade-up" style={`animation-delay: ${0.8 + index * 0.12}s;`}>
  <div class="card-glow" style={`background: radial-gradient(circle, ${p.accentGlow}, transparent 70%);`} />
  <div class="card-inner">
    <div class="card-header">
      <div class="card-icon" style={`background-color: ${p.accent}12; border-color: ${p.accent}22; color: ${p.accent};`}>
        {p.name === 'BSNexus' ? (
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
            <path d="M10 6.5h4M10 17.5h4M6.5 10v4M17.5 10v4"/>
          </svg>
        ) : p.name === 'BSage' ? (
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M11 20A7 7 0 0 1 9.8 6.9C15.5 4.9 20 2 20 2s-1.7 5.3-4 9.5C14 15 11 20 11 20z"/>
            <path d="M6.7 17.3s2.1-3.1 5.3-7.3"/>
          </svg>
        ) : (
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d={p.iconPath}/>
          </svg>
        )}
      </div>
    </div>

    <h3 class="card-name">{p.name}</h3>
    <div class="card-detail" style={`color: ${p.accent};`}>{detail}</div>
    <p class="card-desc">{desc}</p>
  </div>
</a>

<style>
  .product-card {
    border-radius: 14px;
    border: 1px solid #2a2d42;
    background-color: #111218;
    padding: 28px;
    position: relative;
    overflow: hidden;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .product-card:hover {
    transform: translateY(-4px);
    border-color: rgba(99,102,241,0.3);
  }
  .card-glow {
    position: absolute;
    top: -40px;
    left: 50%;
    transform: translateX(-50%);
    width: 200px;
    height: 80px;
    border-radius: 50%;
    pointer-events: none;
  }
  .card-inner {
    position: relative;
  }
  .card-header {
    display: flex;
    align-items: center;
    margin-bottom: 18px;
  }
  .card-icon {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    border: 1px solid;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .card-name {
    font-size: 1.25rem;
    font-weight: 700;
    color: #f2f3f7;
    margin: 0 0 6px;
    letter-spacing: -0.02em;
  }
  .card-detail {
    font-size: 0.75rem;
    font-weight: 500;
    margin-bottom: 10px;
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: -0.01em;
  }
  .card-desc {
    font-size: 0.9375rem;
    color: #8187a8;
    margin: 0;
    line-height: 1.6;
  }
</style>
