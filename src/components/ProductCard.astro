---
import type { Product } from '@/lib/pricing.repository';

interface Props {
  product: Product;
  index: number;
  locale?: 'ko' | 'en';
}

const { product, index, locale = 'ko' } = Astro.props;
const prefix = locale === 'en' ? '/en' : '';
---

<a href={`${prefix}/products/${product.id}`} class="product-card fade-up" style={`animation-delay: ${0.8 + index * 0.12}s;`}>
  <div class="card-glow" style={`background: radial-gradient(circle, ${product.accentColor}26, transparent 70%);`} />
  <div class="card-inner">
    <div class="card-header">
      <div class="card-icon" style={`background-color: ${product.accentColor}12; border-color: ${product.accentColor}22; color: ${product.accentColor};`}>
        <Fragment set:html={product.iconSvg} />
      </div>
    </div>

    <h3 class="card-name">{product.name}</h3>
    <div class="card-detail" style={`color: ${product.accentColor};`}>{product.detail}</div>
    <p class="card-desc">{product.tagline}</p>
  </div>
</a>

<style>
  .product-card {
    border-radius: 14px;
    border: 1px solid #2a2d42;
    background-color: #111218;
    padding: 28px;
    position: relative;
    overflow: hidden;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .product-card:hover {
    transform: translateY(-4px);
    border-color: rgba(99,102,241,0.3);
  }
  .card-glow {
    position: absolute;
    top: -40px;
    left: 50%;
    transform: translateX(-50%);
    width: 200px;
    height: 80px;
    border-radius: 50%;
    pointer-events: none;
  }
  .card-inner {
    position: relative;
  }
  .card-header {
    display: flex;
    align-items: center;
    margin-bottom: 18px;
  }
  .card-icon {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    border: 1px solid;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .card-name {
    font-size: 1.25rem;
    font-weight: 700;
    color: #f2f3f7;
    margin: 0 0 6px;
    letter-spacing: -0.02em;
  }
  .card-detail {
    font-size: 0.75rem;
    font-weight: 500;
    margin-bottom: 10px;
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: -0.01em;
  }
  .card-desc {
    font-size: 0.9375rem;
    color: #8187a8;
    margin: 0;
    line-height: 1.6;
  }
</style>
