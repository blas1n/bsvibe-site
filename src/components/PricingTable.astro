---
import type { ProductPricing } from '@/data/pricing';

interface Props {
  pricing: ProductPricing;
}

const { pricing } = Astro.props;
---

<div class="pricing-product">
  <h2 class="product-name" style={`color: ${pricing.accent};`}>{pricing.product}</h2>
  <div class="tiers">
    {pricing.tiers.map(tier => (
      <div class:list={['tier-card', { highlighted: tier.highlighted }]}
           style={tier.highlighted ? `border-color: ${pricing.accent}40;` : ''}>
        <div class="tier-header">
          <h3 class="tier-name">{tier.name}</h3>
          <div class="tier-price">
            <span class="price">{tier.price}</span>
            <span class="period">{tier.period}</span>
          </div>
          <p class="tier-desc">{tier.description}</p>
        </div>
        <ul class="tier-features">
          {tier.features.map(f => (
            <li>
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke={pricing.accent} stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3.5 8l3 3 6-6"/>
              </svg>
              {f}
            </li>
          ))}
        </ul>
        <a href={tier.price === '문의' || tier.price === 'Contact' ? 'mailto:contact@bsvibe.dev' : `https://auth.bsvibe.dev/signup?redirect_uri=${encodeURIComponent('https://bsvibe.dev/auth/callback')}`}
           class:list={['tier-cta', { primary: tier.highlighted }]}
           style={tier.highlighted ? `background-color: ${pricing.accent}; color: #fff;` : ''}>
          {tier.cta}
        </a>
      </div>
    ))}
  </div>
</div>

<style>
  .pricing-product {
    margin-bottom: 64px;
  }
  .product-name {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 20px;
    letter-spacing: -0.02em;
  }
  .tiers {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 14px;
  }
  .tier-card {
    border-radius: 14px;
    border: 1px solid #2a2d42;
    background-color: #111218;
    padding: 28px;
    display: flex;
    flex-direction: column;
  }
  .tier-card.highlighted {
    background-color: #13141f;
  }
  .tier-header {
    margin-bottom: 20px;
  }
  .tier-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: #8187a8;
    margin-bottom: 8px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .tier-price {
    margin-bottom: 8px;
  }
  .price {
    font-size: 2rem;
    font-weight: 800;
    color: #f2f3f7;
    letter-spacing: -0.03em;
  }
  .period {
    font-size: 0.875rem;
    color: #5a5f7d;
  }
  .tier-desc {
    font-size: 0.8125rem;
    color: #5a5f7d;
    margin: 0;
  }
  .tier-features {
    list-style: none;
    padding: 0;
    margin: 0 0 24px;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .tier-features li {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.875rem;
    color: #a8adc6;
  }
  .tier-cta {
    display: block;
    text-align: center;
    padding: 10px 20px;
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s ease;
    border: 1px solid #2a2d42;
    color: #8187a8;
  }
  .tier-cta:hover {
    border-color: #8187a8;
    color: #f2f3f7;
  }
  .tier-cta.primary {
    border: none;
  }
  .tier-cta.primary:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }
</style>
