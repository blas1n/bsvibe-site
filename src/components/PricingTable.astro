---
import type { ProductWithPrices } from '@/lib/pricing.repository';
import { formatPrice, formatPeriod } from '@/lib/pricing.repository';
import type { Locale } from '@/i18n';

interface Props {
  product: ProductWithPrices;
  locale: Locale;
}

const { product, locale } = Astro.props;
const ctaSignup = locale === 'en' ? 'Get Started' : '시작하기';
const ctaContact = locale === 'en' ? 'Contact Us' : '문의하기';
---

<div class="pricing-product">
  <h2 class="product-name" style={`color: ${product.accentColor};`}>{product.name}</h2>
  <div class="tiers">
    {product.prices.map(tier => {
      const ctaLabel = tier.isContactOnly ? ctaContact : ctaSignup;
      const ctaHref = tier.isContactOnly
        ? 'mailto:contact@bsvibe.dev'
        : `https://auth.bsvibe.dev/signup?redirect_uri=${encodeURIComponent('https://bsvibe.dev/auth/callback')}`;
      return (
        <div class:list={['tier-card', { highlighted: tier.isHighlighted }]}
             style={tier.isHighlighted ? `border-color: ${product.accentColor}40;` : ''}>
          <div class="tier-header">
            <h3 class="tier-name">{tier.displayName}</h3>
            <div class="tier-price">
              <span class="price">{formatPrice(tier, locale)}</span>
              <span class="period">{formatPeriod(tier, locale)}</span>
            </div>
            {tier.description && <p class="tier-desc">{tier.description}</p>}
          </div>
          <ul class="tier-features">
            {tier.features.map(f => (
              <li>
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke={product.accentColor} stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M3.5 8l3 3 6-6"/>
                </svg>
                {f}
              </li>
            ))}
          </ul>
          <a href={ctaHref}
             class:list={['tier-cta', { primary: tier.isHighlighted }]}
             style={tier.isHighlighted ? `background-color: ${product.accentColor}; color: #fff;` : ''}>
            {ctaLabel}
          </a>
        </div>
      );
    })}
  </div>
</div>

<style>
  .pricing-product {
    margin-bottom: 64px;
  }
  .product-name {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 20px;
    letter-spacing: -0.02em;
  }
  .tiers {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 14px;
  }
  .tier-card {
    border-radius: 14px;
    border: 1px solid #2a2d42;
    background-color: #111218;
    padding: 28px;
    display: flex;
    flex-direction: column;
  }
  .tier-card.highlighted {
    background-color: #13141f;
  }
  .tier-header {
    margin-bottom: 20px;
  }
  .tier-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: #8187a8;
    margin-bottom: 8px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .tier-price {
    margin-bottom: 8px;
  }
  .price {
    font-size: 2rem;
    font-weight: 800;
    color: #f2f3f7;
    letter-spacing: -0.03em;
  }
  .period {
    font-size: 0.875rem;
    color: #5a5f7d;
  }
  .tier-desc {
    font-size: 0.8125rem;
    color: #5a5f7d;
    margin: 0;
  }
  .tier-features {
    list-style: none;
    padding: 0;
    margin: 0 0 24px;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .tier-features li {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.875rem;
    color: #a8adc6;
  }
  .tier-cta {
    display: block;
    text-align: center;
    padding: 10px 20px;
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s ease;
    border: 1px solid #2a2d42;
    color: #8187a8;
  }
  .tier-cta:hover {
    border-color: #8187a8;
    color: #f2f3f7;
  }
  .tier-cta.primary {
    border: none;
  }
  .tier-cta.primary:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }
</style>
