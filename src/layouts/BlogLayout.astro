---
import MainLayout from './MainLayout.astro';
import type { Locale } from '@/i18n';

interface Props {
  title: string;
  description: string;
  locale?: Locale;
  date?: Date;
  author?: string;
  tags?: string[];
}

const { title, description, locale = 'ko', date, author, tags = [] } = Astro.props;
const prefix = locale === 'en' ? '/en' : '';
const backLabel = locale === 'en' ? '← Back to Blog' : '← 블로그로 돌아가기';
const formattedDate = date ? new Intl.DateTimeFormat(locale === 'en' ? 'en-US' : 'ko-KR', {
  year: 'numeric', month: 'long', day: 'numeric',
}).format(date) : '';
---

<MainLayout title={`${title} — BSVibe Blog`} description={description} locale={locale}>
  <article class="blog-article">
    <a href={`${prefix}/blog`} class="back-link">{backLabel}</a>

    <header class="article-header">
      <h1>{title}</h1>
      <div class="article-meta">
        {formattedDate && <time>{formattedDate}</time>}
        {author && <span class="author">· {author}</span>}
      </div>
      {tags.length > 0 && (
        <div class="article-tags">
          {tags.map(tag => <span class="tag">{tag}</span>)}
        </div>
      )}
    </header>

    <div class="article-body">
      <slot />
    </div>
  </article>
</MainLayout>

<style>
  .blog-article {
    max-width: 720px;
    margin: 0 auto;
    padding: 16px 24px 120px;
  }
  .back-link {
    display: inline-block;
    margin-bottom: 32px;
    color: #8187a8;
    font-size: 0.875rem;
    text-decoration: none;
  }
  .back-link:hover {
    color: #f2f3f7;
  }
  .article-header h1 {
    color: #f2f3f7;
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: 12px;
  }
  .article-meta {
    color: #5a5f7d;
    font-size: 0.875rem;
    margin-bottom: 16px;
    display: flex;
    gap: 4px;
  }
  .article-tags {
    display: flex;
    gap: 8px;
    margin-bottom: 48px;
  }
  .tag {
    font-size: 0.75rem;
    font-weight: 600;
    color: #818cf8;
    padding: 2px 10px;
    border-radius: 9999px;
    background-color: rgba(99,102,241,0.08);
    border: 1px solid rgba(99,102,241,0.15);
  }
  .article-body {
    color: #a8adc6;
    line-height: 1.8;
    font-size: 0.9375rem;
  }
  .article-body :global(h1),
  .article-body :global(h2),
  .article-body :global(h3) {
    color: #f2f3f7;
    margin-top: 2em;
    margin-bottom: 0.5em;
    letter-spacing: -0.02em;
  }
  .article-body :global(h2) { font-size: 1.5rem; }
  .article-body :global(h3) { font-size: 1.25rem; }
  .article-body :global(p) { margin-bottom: 1em; }
  .article-body :global(ul), .article-body :global(ol) {
    padding-left: 20px;
    margin-bottom: 1em;
  }
  .article-body :global(li) { margin-bottom: 0.5em; }
  .article-body :global(strong) { color: #e4e6ee; }
  .article-body :global(a) { color: #818cf8; text-decoration: none; }
  .article-body :global(a:hover) { text-decoration: underline; }
  .article-body :global(code) {
    font-family: 'JetBrains Mono', monospace;
    background-color: rgba(99,102,241,0.08);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.875em;
  }
  .article-body :global(pre) {
    background-color: #111218;
    border: 1px solid #2a2d42;
    border-radius: 8px;
    padding: 16px;
    overflow-x: auto;
    margin-bottom: 1em;
  }
  .article-body :global(pre code) {
    background: none;
    padding: 0;
  }
</style>
